{
  "name": "@abcnx/metats",
  "version": "0.1.0",
  "description": "A TypeScript tool library for common utilities and helpers",
  "keywords": [
    "typescript",
    "utilities",
    "toolkit",
    "helpers"
  ],
  "license": "Apache-2.0",
  "author": "abcnx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abcnx/MetaTS.git"
  },
  "bugs": {
    "url": "https://github.com/abcnx/MetaTS/issues"
  },
  "homepage": "https://github.com/abcnx/MetaTS#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:type": "tsc --project tsconfig.build.json --outDir dist --declaration --emitDeclarationOnly",
    "dev": "tsup --watch",
    "lint": "eslint src/ test/ --ext .ts",
    "lint:fix": "eslint src/ test/ --ext .ts --fix",
    "format": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
